# Copy to .env.local (git-ignored) and fill in your Desktop OAuth client values.
# Desktop client type in Google Cloud Console: "Desktop app"
# Web client type: "Web application" — set redirect URI to https://yourdomain.com/oauth-callback.html
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=GOCSPX-...
