{
  "name": "impersonal-finance",
  "version": "1.0.0",
  "description": "A local-first personal finance tracking SPA",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "prettier --list-different --write \"src/**/*.{ts,tsx,css}\" && eslint . && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "keywords": [
    "finance",
    "personal-finance",
    "react",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@mantine/charts": "^8.3.15",
    "@mantine/core": "^8.3.15",
    "@mantine/dates": "^8.3.15",
    "@mantine/form": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/notifications": "^8.3.15",
    "@tabler/icons-react": "^3.37.1",
    "@vitejs/plugin-react": "^5.1.4",
    "ag-grid-community": "^35.1.0",
    "ag-grid-react": "^35.1.0",
    "arquero": "^8.0.3",
    "dayjs": "^1.11.19",
    "dexie": "^4.3.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite-plugin-eslint": "^1.8.1"
  }
}
